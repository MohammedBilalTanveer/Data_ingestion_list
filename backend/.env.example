# Copy this file to .env for local development
# In Render, set these in the Environment tab of your service dashboard

# Comma-separated list of allowed frontend origins (leave blank to allow all)
FRONTEND_URL=https://your-app.vercel.app

# Where PDFs are stored — Render mounts the persistent disk here automatically
PDF_STORAGE_PATH=/opt/render/project/pdfs

# Karnataka CEO voter list config
DISTRICT=BANGALORE URBAN
AC_NUMBER=88

# Port is set automatically by Render; override only for local dev if needed
# PORT=5000
