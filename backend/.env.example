# Copy this file to .env for local development
# In Render, set these in the Environment tab of your service dashboard

# Comma-separated list of allowed frontend origins (leave blank to allow all)
FRONTEND_URL=https://data-ingestion-list.vercel.app

# ============================================================================
# AUTHENTICATION - For Download Access (NO DATABASE NEEDED)
# ============================================================================
# IMPORTANT: Set secure credentials for download access
# Leave empty to disable authentication (allow anyone to download)
DOWNLOAD_USERNAME=admin@example.com
DOWNLOAD_PASSWORD=SecurePassword123!

# ============================================================================
# PDF STORAGE CONFIGURATION - Choose ONE of the following:
# ============================================================================

# Option 1: LOCAL STORAGE (for development)
# PDF_STORAGE_PATH=/path/to/local/pdfs

# Option 2: AWS S3 (recommended for production on Render)
USE_S3=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME

# Option 3: Render Persistent Disk (if you purchase a disk on Render)
# PDF_STORAGE_PATH=/opt/render/project/pdfs

# ============================================================================
# Karnataka CEO voter list config
# ============================================================================
DISTRICT=BANGALORE URBAN
AC_NUMBER=88

# Port is set automatically by Render; override only for local dev if needed
# PORT=5000
